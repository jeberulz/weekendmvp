# Copy to .env.local for local dev. Vercel: set in project env (Production + Preview).

# --- Beehiiv (subscribe routes + webhook enrollment) ---
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_5fbc631f-7950-4bac-80fe-80ba70dae2da
BEEHIIV_DEFAULT_FORM_ID=7346f13f-9331-48d7-97f8-88c38da780b1
BEEHIIV_DEFAULT_AUTOMATION_ID=aut_50201ecc-8641-43dc-811b-313be270594b
BEEHIIV_SHIPABLE_AUTOMATION_ID=aut_b55c6b1e-330b-4768-b44a-30e9e07ae92a
BEEHIIV_IDEAS_AUTOMATION_ID=aut_cccbc451-43b6-4968-a713-df83afc32cff
# Paid cohort — enrollable ONLY from the Stripe webhook, never from /api/subscribe
BEEHIIV_PAID_AUTOMATION_ID=aut_b55c6b1e-330b-4768-b44a-30e9e07ae92a

# --- Stripe (ship·able workshop) ---
# STRIPE_SECRET_KEY is OPTIONAL for the current Payment-Link flow.
# The webhook does signature verification only (no server-side API calls), so
# only STRIPE_WEBHOOK_SECRET is required. Set the key later if you add
# checkout.sessions.create, refunds, or customer/subscription queries.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Convex ---
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# --- Next.js cache invalidation (Convex http action → /api/revalidate) ---
REVALIDATE_SECRET=

# --- Site ---
NEXT_PUBLIC_BASE_URL=https://weekendmvp.app
LEGACY_ORIGIN=https://legacy.weekendmvp.app

# --- Analytics (consent-gated) ---
NEXT_PUBLIC_GA_ID=G-Z1NYERTKRS
NEXT_PUBLIC_META_PIXEL_ID=1602726847528813

# --- OG generation (build-time pipeline, carried forward) ---
RECRAFT_API_KEY=
OPENAI_API_KEY=
